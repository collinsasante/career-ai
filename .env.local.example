# PathWise — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
#
# ── STAGING vs PRODUCTION ─────────────────────────
# Use a separate Airtable base for staging so you don't
# pollute real user data while testing.
#
#   Staging:    AIRTABLE_BASE_ID=appXXXXXXXXSTAGING
#   Production: AIRTABLE_BASE_ID=appXXXXXXXXPROD
#
# The same pattern applies to Firebase projects.
# ─────────────────────────────────────────────────

# ── JWT ──────────────────────────────────────────
# Min 32 chars. Generate: openssl rand -base64 32
JWT_SECRET=your-secret-key-minimum-32-characters

# ── App ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: https://yourdomain.com

# ── Anthropic ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Firebase ─────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
FIREBASE_PROJECT_ID=your-project-id
# Staging: use a separate Firebase project (e.g. your-project-staging)

# ── scikit-learn ML API ───────────────────────────
ML_API_URL=http://localhost:8000
# Production: https://your-ml-api.fly.dev (or Railway, Render, etc.)

# ── Airtable ─────────────────────────────────────
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
# Staging base should mirror production schema exactly.
# Required tables: Profiles, Recommendations, Roadmaps, RoadmapProgress

# ── Sentry ───────────────────────────────────────
# Get DSN from sentry.io → Project Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0
# Used during build to upload source maps (CI only):
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=sntrys_xxxx
