{
  "name": "pathwise",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "deploy": "opennextjs-cloudflare build && wrangler deploy",
    "preview": "opennextjs-cloudflare build && wrangler dev",
    "db:migrate": "wrangler d1 execute pathwise-db --local --file=src/lib/db/schema.sql",
    "db:seed": "wrangler d1 execute pathwise-db --local --file=src/lib/db/seed.sql",
    "db:migrate:prod": "wrangler d1 execute pathwise-db --file=src/lib/db/schema.sql",
    "db:seed:prod": "wrangler d1 execute pathwise-db --file=src/lib/db/seed.sql"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@sentry/nextjs": "^10.47.0",
    "airtable": "^0.12.2",
    "clsx": "^2.1.1",
    "firebase": "^12.11.0",
    "jose": "^5.9.6",
    "lucide-react": "^0.460.0",
    "next": "15.3.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.10.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@opennextjs/cloudflare": "^1.18.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "eslint": "^8",
    "eslint-config-next": "15.3.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5",
    "wrangler": "^4.65.0"
  }
}
